      m_Calls: []
  m_text: "Se mueve en diagonal, como un obispo en un tablero de iglesia. \r\n\r\nMovimiento:
    Puede moverse todas las casillas que quiera en diagonal.\r\nCaptura: Captura
    la primera pieza que se encuentre en su camino diagonal.\r\nNo puede saltar por
    encima de otras piezas.\r\nCada jugador tiene un Alfil que se mueve en casillas
    blancas y otro en casillas negras.\r\n       "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 1dbf3118d1864df489cb01faed535ae6, type: 2}
  m_sharedMaterial: {fileID: -6714756947921302118, guid: 1dbf3118d1864df489cb01faed535ae6, type: 2}
