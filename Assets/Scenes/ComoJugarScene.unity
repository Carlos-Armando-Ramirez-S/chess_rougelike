  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Es la pieza m\xE1s numerosa pero la menos poderosa. \r\n\r\nMovimiento:
    Solo se mueve una casilla hacia adelante.\r\nPrimer Movimiento: En su primer
    movimiento, puede avanzar dos casillas hacia adelante si lo deseas.\r\nCaptura:
    Captura a otras piezas en diagonal, una casilla hacia adelante a la izquierda
    o a la derecha.\r\nPromoci\xF3n: Si un pe\xF3n llega al otro lado del tablero,
    se transforma en una pieza m\xE1s poderosa (Reina, Torre, Alfil o Caballo).\r\n     "
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 1dbf3118d1864df489cb01faed535ae6, type: 2}
